rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    match /domande/{questionId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    match /giocatori/{playerId} {
      allow read: if isSignedIn();
      allow create: if (isSignedIn() && request.auth.uid == playerId) || isAdmin();
      allow update: if (isSignedIn() && request.auth.uid == playerId) || isAdmin();
      allow delete: if isAdmin();
    }

    match /risposte_date/{answerId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
        && request.resource.data.id_giocatore == request.auth.uid;
      allow update, delete: if false;
    }

    match /stato_partita/{docId} {
      allow read: if isSignedIn();
      allow update: if isSignedIn()
        && (resource.data.turno_attuale_id == request.auth.uid || isAdmin());
      allow create: if isAdmin();
      allow delete: if isAdmin();
    }

    match /admins/{adminId} {
      allow read: if isSignedIn() && (request.auth.uid == adminId || isAdmin());
      allow write: if false;
    }

    // La collection mail viene scritta dal backend (Cloud Functions/Admin SDK).
    match /mail/{mailId} {
      allow read, write: if false;
    }
  }
}
